{
	"name": "firstelementjp/swift-csv",
	"description": "Swift CSV - Simple CSV Management Without the Complexity.",
	"type": "wordpress-plugin",
	"license": "GPL-2.0+",
	"homepage": "https://github.com/firstelementjp/swift-csv",
	"require": {
		"php": ">=8.0"
	},
	"require-dev": {
		"squizlabs/php_codesniffer": "^3.10",
		"phpcsstandards/phpcsutils": "^1.2",
		"dealerdirect/phpcodesniffer-composer-installer": "^1.0",
		"phpcompatibility/php-compatibility": "^9.3",
		"phpcompatibility/phpcompatibility-wp": "^2.1",
		"wp-coding-standards/wpcs": "^3.3",
		"phpcsstandards/phpcsextra": "^1.5",
		"phpunit/phpunit": "^9.6",
		"wp-phpunit/wp-phpunit": "^6.5",
		"yoast/phpunit-polyfills": "^2.0"
	},
	"scripts": {
		"phpcs": "phpcs",
		"phpcbf": "phpcbf",
		"test": "phpunit",
		"test-coverage": "phpunit --coverage-html tests/coverage",
		"test-unit": "phpunit --testsuite=\"Swift CSV Unit Tests\"",
		"test-integration": "phpunit --testsuite=\"Swift CSV Integration Tests\""
	},
	"config": {
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true
		}
	}
}
