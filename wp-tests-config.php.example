<?php
/**
 * WordPress test configuration example for Swift CSV
 *
 * Copy this file to wp-tests-config.php and adjust the environment as needed.
 *
 * @package Swift_CSV\Tests
 */

$swift_csv_mysql_socket = getenv( 'MYSQL_UNIX_PORT' );

if ( $swift_csv_mysql_socket ) {
	ini_set( 'mysqli.default_socket', $swift_csv_mysql_socket );
	ini_set( 'pdo_mysql.default_socket', $swift_csv_mysql_socket );
}

if ( ! defined( 'ABSPATH' ) ) {
	$swift_csv_wp_dir         = false;
	$swift_csv_possible_paths = [
		'../../wp',
		'../../../wp',
		dirname( __DIR__, 2 ) . '/wp',
		dirname( __DIR__, 3 ),
	];

	foreach ( $swift_csv_possible_paths as $swift_csv_candidate_path ) {
		if ( file_exists( $swift_csv_candidate_path . '/wp-load.php' ) ) {
			$swift_csv_wp_dir = $swift_csv_candidate_path;
			break;
		}
	}

	if ( $swift_csv_wp_dir ) {
		define( 'ABSPATH', rtrim( $swift_csv_wp_dir, '/\\' ) . '/' );
	}
}

define( 'DB_NAME', getenv( 'DB_NAME' ) ? getenv( 'DB_NAME' ) : 'local' );
define( 'DB_USER', getenv( 'DB_USER' ) ? getenv( 'DB_USER' ) : 'root' );
define( 'DB_PASSWORD', getenv( 'DB_PASSWORD' ) ? getenv( 'DB_PASSWORD' ) : 'root' );
define(
	'DB_HOST',
	getenv( 'DB_HOST' ) ? getenv( 'DB_HOST' ) : 'localhost'
);
define( 'DB_CHARSET', 'utf8' );
define( 'DB_COLLATE', '' );

if ( ! defined( 'WP_TESTS_DOMAIN' ) ) {
	define( 'WP_TESTS_DOMAIN', 'example.org' );
}

if ( ! defined( 'WP_TESTS_EMAIL' ) ) {
	define( 'WP_TESTS_EMAIL', 'admin@example.org' );
}

if ( ! defined( 'WP_TESTS_TITLE' ) ) {
	define( 'WP_TESTS_TITLE', 'Swift CSV Test Site' );
}

if ( ! defined( 'WP_PHP_BINARY' ) ) {
	define( 'WP_PHP_BINARY', 'php' );
}

define( 'WP_DEBUG', true );
define( 'WP_DEBUG_LOG', true );
define( 'SCRIPT_DEBUG', false );

$table_prefix = 'wptests_';
