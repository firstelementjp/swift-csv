{
	"name": "swift-csv",
	"version": "0.9.7",
	"description": "Swift CSV - Simple CSV Management Without the Complexity.",
	"license": "GPL-2.0+",
	"engines": {
		"node": ">=18.0.0"
	},
	"scripts": {
		"dev": "npm run watch:all",
		"watch:all": "npm run watch:modules & npm run watch:css",
		"watch:modules": "npm run watch:core & npm run watch:export & npm run watch:import & npm run watch:license & npm run watch:main",
		"watch:core": "esbuild assets/js/swift-csv-core.js --minify --outfile=assets/js/swift-csv-core.min.js --watch=forever",
		"watch:export": "npm run watch:export:unified & npm run watch:export:modules",
		"watch:export:unified": "esbuild assets/js/swift-csv-export-unified.js --minify --outfile=assets/js/swift-csv-export-unified.min.js --watch=forever",
		"watch:export:modules": "npm run watch:export:ajax & npm run watch:export:download & npm run watch:export:form & npm run watch:export:ui & npm run watch:export:logs & npm run watch:export:original",
		"watch:export:ajax": "esbuild assets/js/export/swift-csv/ajax.js --minify --outfile=assets/js/export/swift-csv/ajax.min.js --watch=forever",
		"watch:export:download": "esbuild assets/js/export/swift-csv/download.js --minify --outfile=assets/js/export/swift-csv/download.min.js --watch=forever",
		"watch:export:form": "esbuild assets/js/export/swift-csv/form.js --minify --outfile=assets/js/export/swift-csv/form.min.js --watch=forever",
		"watch:export:ui": "esbuild assets/js/export/swift-csv/ui.js --minify --outfile=assets/js/export/swift-csv/ui.min.js --watch=forever",
		"watch:export:logs": "esbuild assets/js/export/swift-csv/logs.js --minify --outfile=assets/js/export/swift-csv/logs.min.js --watch=forever",
		"watch:export:original": "esbuild assets/js/export/swift-csv/original.js --minify --outfile=assets/js/export/swift-csv/original.min.js --watch=forever",
		"watch:import": "esbuild assets/js/swift-csv-import.js --minify --outfile=assets/js/swift-csv-import.min.js --watch=forever",
		"watch:license": "esbuild assets/js/swift-csv-license.js --minify --outfile=assets/js/swift-csv-license.min.js --watch=forever",
		"watch:main": "esbuild assets/js/swift-csv-main.js --minify --outfile=assets/js/swift-csv-main.min.js --watch=forever",
		"watch:css": "esbuild assets/css/swift-csv-style.css --minify --outfile=assets/css/swift-csv-style.min.css --watch=forever",
		"build": "npm run build:modules && npm run build:css",
		"build:modules": "npm run build:core && npm run build:export && npm run build:import && npm run build:license && npm run build:main",
		"build:core": "esbuild assets/js/swift-csv-core.js --minify --outfile=assets/js/swift-csv-core.min.js",
		"build:export": "npm run build:export:unified && npm run build:export:modules",
		"build:export:unified": "esbuild assets/js/swift-csv-export-unified.js --minify --outfile=assets/js/swift-csv-export-unified.min.js",
		"build:export:modules": "npm run build:export:ajax && npm run build:export:download && npm run build:export:form && npm run build:export:ui && npm run build:export:logs && npm run build:export:original",
		"build:export:ajax": "esbuild assets/js/export/swift-csv/ajax.js --minify --outfile=assets/js/export/swift-csv/ajax.min.js",
		"build:export:download": "esbuild assets/js/export/swift-csv/download.js --minify --outfile=assets/js/export/swift-csv/download.min.js",
		"build:export:form": "esbuild assets/js/export/swift-csv/form.js --minify --outfile=assets/js/export/swift-csv/form.min.js",
		"build:export:ui": "esbuild assets/js/export/swift-csv/ui.js --minify --outfile=assets/js/export/swift-csv/ui.min.js",
		"build:export:logs": "esbuild assets/js/export/swift-csv/logs.js --minify --outfile=assets/js/export/swift-csv/logs.min.js",
		"build:export:original": "esbuild assets/js/export/swift-csv/original.js --minify --outfile=assets/js/export/swift-csv/original.min.js",
		"build:import": "esbuild assets/js/swift-csv-import.js --minify --outfile=assets/js/swift-csv-import.min.js",
		"build:license": "esbuild assets/js/swift-csv-license.js --minify --outfile=assets/js/swift-csv-license.min.js",
		"build:main": "esbuild assets/js/swift-csv-main.js --minify --outfile=assets/js/swift-csv-main.min.js",
		"build:css": "esbuild assets/css/swift-csv-style.css --minify --outfile=assets/css/swift-csv-style.min.css",
		"lint:js": "eslint . --ext .js",
		"lint:js:fix": "eslint . --ext .js --fix",
		"format": "prettier --write .",
		"format:check": "prettier --check ."
	},
	"devDependencies": {
		"@wordpress/babel-plugin-makepot": "^6.39.0",
		"@wordpress/eslint-plugin": "^14.0.0",
		"@wordpress/scripts": "^26.0.0",
		"esbuild": "^0.27.2",
		"eslint": "^8.0.0",
		"eslint-config-wordpress": "^2.0.0",
		"prettier": "^3.4.2"
	}
}
